<%- include('../header') %>

<div class="page-header fade-in">
    <div class="flex justify-between items-center">
        <div>
            <h1 class="page-title">Product Management</h1>
            <p class="page-subtitle">Manage your products with modern interface</p>
        </div>
        <a href="/product/addProductPage" class="btn btn-primary" style="padding: 16px 24px; font-weight: 700; font-size: 16px;">
            <i class="fas fa-box"></i>
            Add New Product
        </a>
    </div>
</div>

<div class="grid grid-4 mb-3">
    <div class="stat-card fade-in" style="animation-delay: 0.1s; border-left-color: var(--primary);">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <div>
                <div class="stat-number"><%= allProduct ? allProduct.length : 0 %></div>
                <div class="stat-label">Total Products</div>
            </div>
            <div style="width: 60px; height: 60px; background: linear-gradient(135deg, rgba(99, 102, 241, 0.15), rgba(99, 102, 241, 0.05)); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                <i class="fas fa-box" style="color: var(--primary); font-size: 24px;"></i>
            </div>
        </div>
    </div>
    
    <div class="stat-card fade-in" style="animation-delay: 0.15s; border-left-color: var(--success);">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <div>
                <div class="stat-number" style="color: var(--success);">
                    <% 
                        const categories = allProduct ? [...new Set(allProduct.map(p => p.category_id ? p.category_id._id : null).filter(Boolean))] : [];
                    %>
                    <%= categories.length %>
                </div>
                <div class="stat-label">Categories</div>
            </div>
            <div style="width: 60px; height: 60px; background: linear-gradient(135deg, rgba(16, 185, 129, 0.15), rgba(16, 185, 129, 0.05)); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                <i class="fas fa-folder" style="color: var(--success); font-size: 24px;"></i>
            </div>
        </div>
    </div>
    
    <div class="stat-card fade-in" style="animation-delay: 0.2s; border-left-color: var(--warning);">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <div>
                <div class="stat-number" style="color: var(--warning);">
                    <% 
                        const subcategories = allProduct ? [...new Set(allProduct.map(p => p.subcategory_id ? p.subcategory_id._id : null).filter(Boolean))] : [];
                    %>
                    <%= subcategories.length %>
                </div>
                <div class="stat-label">SubCategories</div>
            </div>
            <div style="width: 60px; height: 60px; background: linear-gradient(135deg, rgba(245, 158, 11, 0.15), rgba(245, 158, 11, 0.05)); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                <i class="fas fa-sitemap" style="color: var(--warning); font-size: 24px;"></i>
            </div>
        </div>
    </div>
    
    <div class="stat-card fade-in" style="animation-delay: 0.25s; border-left-color: #8b5cf6;">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <div>
                <div class="stat-number" style="color: #8b5cf6;">
                    <% 
                        const totalValue = allProduct ? allProduct.reduce((sum, p) => sum + (p.product_price || 0), 0) : 0;
                    %>
                    ₹<%= totalValue.toLocaleString('en-IN') %>
                </div>
                <div class="stat-label">Total Value</div>
            </div>
            <div style="width: 60px; height: 60px; background: linear-gradient(135deg, rgba(139, 92, 246, 0.15), rgba(139, 92, 246, 0.05)); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                <i class="fas fa-rupee-sign" style="color: #8b5cf6; font-size: 24px;"></i>
            </div>
        </div>
    </div>
</div>

<div class="card fade-in" style="animation-delay: 0.3s;">
    <div class="card-header">
        <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px;">
            <h3 class="card-title">
                <i class="fas fa-th-large"></i>
                Product Gallery (<span id="productCount"><%= allProduct ? allProduct.length : 0 %></span>)
            </h3>
            <div style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
                <input type="text" id="searchInput" placeholder="🔍 Search products..." style="padding: 10px 16px; border: 2px solid var(--border); border-radius: 8px; font-size: 14px; width: 200px;" onkeyup="filterProducts()">
                <select id="categoryFilter" style="padding: 10px 16px; border: 2px solid var(--border); border-radius: 8px; font-size: 14px; font-weight: 600;" onchange="filterProducts()">
                    <option value="">All Categories</option>
                    <% if (allProduct && allProduct.length > 0) { %>
                        <% const categories = [...new Set(allProduct.map(p => p.category_id ? p.category_id.category_name : 'N/A'))]; %>
                        <% categories.forEach(cat => { %>
                            <option value="<%= cat %>"><%= cat %></option>
                        <% }) %>
                    <% } %>
                </select>
            </div>
        </div>
    </div>
    <div class="card-body" style="padding: 32px;">
        <% if (allProduct && allProduct.length > 0) { %>
            <div class="grid grid-3" id="productsContainer" style="gap: 28px;">
                <% allProduct.forEach((product, index) => { %>
                <div class="product-card-modern" 
                     data-name="<%= product.product_name.toLowerCase() %>" 
                     data-category="<%= product.category_id ? product.category_id.category_name : 'N/A' %>"
                     style="animation: fadeInUp 0.5s ease-out; animation-delay: <%= (index + 1) * 0.04 %>s; animation-fill-mode: both;">
                    
                    <div class="product-img-wrapper">
                        <% if (product.product_image) { %>
                            <img src="/<%= product.product_image.replace(/\\/g, '/') %>" 
                                 alt="<%= product.product_name %>" 
                                 class="product-img"
                                 onerror="console.log('Image failed:', this.src); this.style.display='none'; this.parentElement.querySelector('.img-fallback').style.display='flex';">
                            <div class="img-fallback" style="display: none;">
                                <i class="fas fa-image"></i>
                                <span>No Image</span>
                            </div>
                        <% } else { %>
                            <div class="img-fallback">
                                <i class="fas fa-image"></i>
                                <span>No Image</span>
                            </div>
                        <% } %>
                        <div class="product-rank">#<%= index + 1 %></div>
                    </div>
                    
                    <div class="product-info">
                        <h4 class="product-name" title="<%= product.product_name %>"><%= product.product_name %></h4>
                        
                        <div class="product-tags">
                            <span class="tag tag-primary"><i class="fas fa-folder"></i> <%= product.category_id ? product.category_id.category_name : 'N/A' %></span>
                            <span class="tag tag-success"><i class="fas fa-sitemap"></i> <%= product.subcategory_id ? product.subcategory_id.subcategory_name : 'N/A' %></span>
                        </div>
                        
                        <p class="product-desc"><%= product.product_description.substring(0, 70) %><%= product.product_description.length > 70 ? '...' : '' %></p>
                        
                        <div class="product-bottom">
                            <div class="product-cost">₹<%= product.product_price %></div>
                            <div class="product-btns">
                                <a href="/product/editProductPage/<%= product._id %>" class="btn-round btn-edit" title="Edit">
                                    <i class="fas fa-pen"></i>
                                </a>
                                <a href="javascript:void(0)" class="btn-round btn-delete" onclick="deleteProduct('<%= product._id %>')" title="Delete">
                                    <i class="fas fa-trash-alt"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>
            <div id="noResults" style="display: none; text-align: center; padding: 80px 20px;">
                <i class="fas fa-search" style="font-size: 72px; color: var(--gray-light); margin-bottom: 24px;"></i>
                <h3 style="color: var(--dark); margin-bottom: 12px; font-size: 24px;">No Products Found</h3>
                <p style="color: var(--gray); font-size: 16px;">Try different search terms or filters</p>
            </div>
        <% } else { %>
            <div class="text-center p-2">
                <div style="width: 140px; height: 140px; background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(99, 102, 241, 0.05)); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 32px; border: 3px dashed var(--primary);">
                    <i class="fas fa-box" style="font-size: 56px; color: var(--primary);"></i>
                </div>
                <h3 style="color: var(--dark); margin-bottom: 16px; font-weight: 800; font-size: 28px;">No Products Found</h3>
                <p style="color: var(--gray); margin-bottom: 32px; font-size: 16px; font-weight: 500; max-width: 400px; margin-left: auto; margin-right: auto;">Your product list is empty. Start adding products to your inventory.</p>
                <a href="/product/addProductPage" class="btn btn-primary" style="padding: 20px 40px; font-weight: 700; font-size: 18px; border-radius: var(--radius-lg);">
                    <i class="fas fa-box"></i>
                    Add First Product
                </a>
            </div>
        <% } %>
    </div>
</div>

<%- include('../footer') %>

<script>
function deleteProduct(productId) {
    Swal.fire({
        title: 'Delete Product?',
        text: "This action cannot be undone!",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#ef4444',
        cancelButtonColor: '#6b7280',
        confirmButtonText: 'Yes, delete it!',
        cancelButtonText: 'Cancel'
    }).then((result) => {
        if (result.isConfirmed) {
            window.location.href = '/product/deleteProduct?productId=' + productId;
        }
    });
}

function filterProducts() {
    const searchValue = document.getElementById('searchInput').value.toLowerCase();
    const categoryValue = document.getElementById('categoryFilter').value;
    const cards = document.querySelectorAll('.product-card-modern');
    let visibleCount = 0;
    
    cards.forEach(card => {
        const name = card.dataset.name;
        const category = card.dataset.category;
        
        const matchSearch = name.includes(searchValue);
        const matchCategory = !categoryValue || category === categoryValue;
        
        if (matchSearch && matchCategory) {
            card.style.display = 'block';
            visibleCount++;
        } else {
            card.style.display = 'none';
        }
    });
    
    document.getElementById('productCount').textContent = visibleCount;
    document.getElementById('noResults').style.display = visibleCount === 0 ? 'block' : 'none';
    document.getElementById('productsContainer').style.display = visibleCount === 0 ? 'none' : 'grid';
}
</script>

<style>
.product-card-modern {
    background: var(--white);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    transition: all 0.3s ease;
    border: 1px solid var(--border);
}

.product-card-modern:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 24px rgba(0,0,0,0.15);
}

.product-img-wrapper {
    position: relative;
    width: 100%;
    height: 260px;
    background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
}

.product-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    padding: 12px;
    transition: transform 0.4s ease;
}

.product-card-modern:hover .product-img {
    transform: scale(1.05);
}

.img-fallback {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    color: var(--gray);
    font-size: 48px;
}

.img-fallback span {
    font-size: 14px;
    font-weight: 600;
}

.product-rank {
    position: absolute;
    top: 16px;
    right: 16px;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: white;
    padding: 8px 16px;
    border-radius: 20px;
    font-weight: 700;
    font-size: 13px;
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.4);
}

.product-info {
    padding: 24px;
}

.product-name {
    font-size: 18px;
    font-weight: 700;
    color: var(--dark);
    margin: 0 0 16px 0;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 50px;
}

.product-tags {
    display: flex;
    gap: 8px;
    margin-bottom: 16px;
    flex-wrap: wrap;
}

.tag {
    font-size: 11px;
    font-weight: 600;
    padding: 6px 12px;
    border-radius: 6px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
}

.tag-primary {
    background: rgba(99, 102, 241, 0.12);
    color: var(--primary);
}

.tag-success {
    background: rgba(16, 185, 129, 0.12);
    color: var(--success);
}

.product-desc {
    font-size: 14px;
    color: var(--gray);
    line-height: 1.6;
    margin-bottom: 20px;
    min-height: 44px;
}

.product-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 20px;
    border-top: 2px solid var(--border);
}

.product-cost {
    font-size: 32px;
    font-weight: 800;
    background: linear-gradient(135deg, #10b981, #059669);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.product-btns {
    display: flex;
    gap: 10px;
}

.btn-round {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    font-size: 16px;
    text-decoration: none;
}

.btn-edit {
    background: rgba(245, 158, 11, 0.15);
    color: var(--warning);
}

.btn-edit:hover {
    background: var(--warning);
    color: white;
    transform: rotate(15deg) scale(1.1);
}

.btn-delete {
    background: rgba(239, 68, 68, 0.15);
    color: var(--danger);
}

.btn-delete:hover {
    background: var(--danger);
    color: white;
    transform: rotate(-15deg) scale(1.1);
}
</style>
