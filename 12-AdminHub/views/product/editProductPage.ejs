<%- include('../header') %>

<div class="page-header fade-in">
    <h1 class="page-title">Edit Product</h1>
    <p class="page-subtitle">Update product information with modern interface</p>
</div>

<div class="card fade-in" style="animation-delay: 0.2s;">
    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-edit"></i>
            Product Update Form
        </h3>
    </div>
    <div class="card-body">
        <form action="/product/editProduct/<%= singleProduct._id %>" method="POST" enctype="multipart/form-data">

            <div class="section-header">
                <div class="section-icon">
                    <i class="fas fa-tag"></i>
                </div>
                <h4 class="section-title">Product Information</h4>
            </div>

            <div class="form-group">
                <label class="form-label">
                    <i class="fas fa-folder" style="color: var(--primary); margin-right: 8px;"></i>
                    Select Category
                </label>
                <select id="category_id" class="form-select" required>
                    <option value="">Select Category</option>
                    <% allCategory.forEach((category) => { %>
                        <option value="<%= category._id %>" <%= singleProduct.category_id.toString() === category._id.toString() ? 'selected' : '' %>><%= category.category_name %></option>
                    <% }) %>
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">
                    <i class="fas fa-folder-open" style="color: var(--primary); margin-right: 8px;"></i>
                    Select SubCategory
                </label>
                <select id="subcategory_id" class="form-select" required>
                    <option value="">Select SubCategory</option>
                    <% allSubCategory.forEach((subCategory) => { %>
                        <option value="<%= subCategory._id %>" <%= singleProduct.subcategory_id.toString() === subCategory._id.toString() ? 'selected' : '' %>><%= subCategory.subcategory_name %></option>
                    <% }) %>
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">
                    <i class="fas fa-layer-group" style="color: var(--primary); margin-right: 8px;"></i>
                    Select Extra Category
                </label>
                <select name="extracategory_id" id="extracategory_id" class="form-select" required>
                    <option value="">Select Extra Category</option>
                    <% allExtraCategory.forEach((extraCategory) => { %>
                        <option value="<%= extraCategory._id %>" <%= singleProduct.extracategory_id.toString() === extraCategory._id.toString() ? 'selected' : '' %>><%= extraCategory.extracategory_name %></option>
                    <% }) %>
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">
                    <i class="fas fa-box" style="color: var(--primary); margin-right: 8px;"></i>
                    Product Name
                </label>
                <input type="text" name="product_name" class="form-input" placeholder="Enter product name" value="<%= singleProduct.product_name %>" required>
            </div>

            <div class="form-group">
                <label class="form-label">
                    <i class="fas fa-dollar-sign" style="color: var(--primary); margin-right: 8px;"></i>
                    Product Price
                </label>
                <input type="number" name="product_price" class="form-input" placeholder="Enter product price" value="<%= singleProduct.product_price %>" required>
            </div>

            <div class="form-group">
                <label class="form-label">
                    <i class="fas fa-align-left" style="color: var(--primary); margin-right: 8px;"></i>
                    Product Description
                </label>
                <textarea name="product_description" class="form-input" rows="4" placeholder="Enter product description" required><%= singleProduct.product_description %></textarea>
            </div>

            <div class="form-group">
                <label class="form-label">
                    <i class="fas fa-image" style="color: var(--primary); margin-right: 8px;"></i>
                    Product Image
                </label>
                <input type="file" name="product_image" class="form-input" accept="image/*">
                <% if (singleProduct.product_image) { %>
                    <div style="margin-top: 12px;">
                        <img src="/<%= singleProduct.product_image %>" alt="Current Image" style="width: 120px; height: 120px; object-fit: cover; border-radius: 8px; border: 2px solid var(--border);">
                    </div>
                <% } %>
            </div>

            <input type="hidden" name="category_id" id="hidden_category_id" value="<%= singleProduct.category_id %>">
            <input type="hidden" name="subcategory_id" id="hidden_subcategory_id" value="<%= singleProduct.subcategory_id %>">

            <div style="border-top: 2px solid var(--border); padding-top: 32px; margin-top: 32px;">
                <div class="flex gap-2 justify-center">
                    <button type="submit" class="btn btn-primary" style="padding: 16px 32px; font-weight: 700; font-size: 16px;">
                        <i class="fas fa-save"></i>
                        Update Product
                    </button>
                    <a href="/product/viewProductsPage" class="btn btn-outline" style="padding: 16px 32px; font-weight: 700; font-size: 16px;">
                        <i class="fas fa-arrow-left"></i>
                        Back to List
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<%- include('../footer') %>

<script>
const allSubCategory = <%- JSON.stringify(allSubCategory) %>;
const allExtraCategory = <%- JSON.stringify(allExtraCategory) %>;

document.getElementById('category_id').addEventListener('change', function() {
    const categoryId = this.value;
    document.getElementById('hidden_category_id').value = categoryId;
    const subcategorySelect = document.getElementById('subcategory_id');
    const extracategorySelect = document.getElementById('extracategory_id');
    
    subcategorySelect.innerHTML = '<option value="">Select SubCategory</option>';
    extracategorySelect.innerHTML = '<option value="">Select Extra Category</option>';
    
    if (categoryId) {
        const filteredSubCategories = allSubCategory.filter(sub => sub.category_id.toString() === categoryId);
        
        filteredSubCategories.forEach(sub => {
            const option = document.createElement('option');
            option.value = sub._id;
            option.textContent = sub.subcategory_name;
            subcategorySelect.appendChild(option);
        });
    }
});

document.getElementById('subcategory_id').addEventListener('change', function() {
    const subcategoryId = this.value;
    document.getElementById('hidden_subcategory_id').value = subcategoryId;
    const extracategorySelect = document.getElementById('extracategory_id');
    
    extracategorySelect.innerHTML = '<option value="">Select Extra Category</option>';
    
    if (subcategoryId) {
        const filteredExtraCategories = allExtraCategory.filter(extra => extra.subcategory_id.toString() === subcategoryId);
        
        filteredExtraCategories.forEach(extra => {
            const option = document.createElement('option');
            option.value = extra._id;
            option.textContent = extra.extracategory_name;
            extracategorySelect.appendChild(option);
        });
    }
});
</script>
