<!DOCTYPE html>
<html lang="en">
    
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=0.9">
    <title>DashPro - Modern Admin Panel</title>
    <link rel="stylesheet" href="/css/app.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.26.18/dist/sweetalert2.all.min.js"></script>
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
</head>

<body>
    <!-- Mobile Menu Button -->
    <button class="mobile-menu-btn" id="mobileMenuBtn">
        <span></span>
        <span></span>
        <span></span>
    </button>

    <!-- Sidebar -->
    <header class="header" id="sidebar">
        <!-- Logo -->
        <div class="nav-brand">
            <a href="/dashboard" class="logo">
                <div class="logo-icon">
                    <i class="fas fa-crown"></i>
                </div>
                <span class="logo-text">DashPro</span>
            </a>
        </div>

        <!-- Navigation Menu -->
        <div class="nav-center">
            <ul class="nav-menu">
                <li class="nav-item">
                    <a href="/dashboard" class="nav-link <%= currentPath === '/dashboard' ? 'active' : '' %>">
                        <i class="fas fa-home"></i>
                        <span>Dashboard</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/addAdmin" class="nav-link <%= currentPath === '/addAdmin' ? 'active' : '' %>">
                        <i class="fas fa-user-plus"></i>
                        <span>Add Admin</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/viewAdmin" class="nav-link <%= currentPath === '/viewAdmin' ? 'active' : '' %>">
                        <i class="fas fa-users"></i>
                        <span>View Admins</span>
                    </a>
                </li>
                <li class="nav-item has-submenu">
                    <a href="#" class="nav-link">
                        <i class="fas fa-folder"></i>
                        <span>Category</span>
                    </a>
                    <ul class="nav-submenu">
                        <li><a href="/category/addCategoryPage" class="<%= currentPath === '/category/addCategoryPage' ? 'active' : '' %>"><i class="fas fa-plus-circle"></i> Add Category</a></li>
                        <li><a href="/category/viewCategoriesPage" class="<%= currentPath === '/category/viewCategoriesPage' ? 'active' : '' %>"><i class="fas fa-list"></i> View Categories</a></li>
                    </ul>
                </li>
                <li class="nav-item has-submenu">
                    <a href="#" class="nav-link">
                        <i class="fas fa-folder-open"></i>
                        <span>SubCategory</span>
                    </a>
                    <ul class="nav-submenu">
                        <li><a href="/subCategory/addSubCategoryPage" class="<%= currentPath === '/subCategory/addSubCategoryPage' ? 'active' : '' %>"><i class="fas fa-plus-circle"></i> Add SubCategory</a></li>
                        <li><a href="/subCategory/viewSubCategoriesPage" class="<%= currentPath === '/subCategory/viewSubCategoriesPage' ? 'active' : '' %>"><i class="fas fa-list"></i> View SubCategories</a></li>
                    </ul>
                </li>
                <li class="nav-item has-submenu">
                    <a href="#" class="nav-link">
                        <i class="fas fa-layer-group"></i>
                        <span>Extra Category</span>
                    </a>
                    <ul class="nav-submenu">
                        <li><a href="/extraCategory/addExtraCategoryPage" class="<%= currentPath === '/extraCategory/addExtraCategoryPage' ? 'active' : '' %>"><i class="fas fa-plus-circle"></i> Add Extra Category</a></li>
                        <li><a href="/extraCategory/viewExtraCategoriesPage" class="<%= currentPath === '/extraCategory/viewExtraCategoriesPage' ? 'active' : '' %>"><i class="fas fa-list"></i> View Extra Categories</a></li>
                    </ul>
                </li>
                <li class="nav-item has-submenu">
                    <a href="#" class="nav-link">
                        <i class="fas fa-box"></i>
                        <span>Products</span>
                    </a>
                    <ul class="nav-submenu">
                        <li><a href="/product/addProductPage" class="<%= currentPath === '/product/addProductPage' ? 'active' : '' %>"><i class="fas fa-plus-circle"></i> Add Product</a></li>
                        <li><a href="/product/viewProductsPage" class="<%= currentPath === '/product/viewProductsPage' ? 'active' : '' %>"><i class="fas fa-list"></i> View Products</a></li>
                    </ul>
                </li>
                <li class="nav-item">
                    <a href="/profile" class="nav-link <%= currentPath === '/profile' ? 'active' : '' %>">
                        <i class="fas fa-user-circle"></i>
                        <span>Profile</span>
                    </a>
                </li>
            </ul>
        </div>

        <!-- User Menu -->
        <div class="nav-actions">
            <div class="user-menu">
                <div class="user-info">
                    <% if (typeof admin !=='undefined' && admin) { %>
                        <% if (admin.profile_image) { %>
                            <img src="/<%= admin.profile_image %>" alt="<%= admin.fname %>" class="user-avatar">
                        <% } else { %>
                            <div class="user-avatar user-avatar-initials">
                                <%= admin.fname.charAt(0) %><%= admin.lname.charAt(0) %>
                            </div>
                        <% } %>
                        <div class="user-details">
                            <span class="user-name"><%= admin.fname %> <%= admin.lname %></span>
                            <span class="user-role">Administrator</span>
                        </div>
                    <% } else { %>
                        <div class="user-avatar user-avatar-initials">AU</div>
                        <div class="user-details">
                            <span class="user-name">Admin User</span>
                            <span class="user-role">Administrator</span>
                        </div>
                    <% } %>
                </div>
                <a href="/logout" class="logout-btn">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Logout</span>
                </a>
            </div>
        </div>
    </header>

    <main class="main">
        <div class="container">