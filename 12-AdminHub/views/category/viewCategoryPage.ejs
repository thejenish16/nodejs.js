<%- include('../header') %>

<div class="page-header fade-in">
    <div class="flex justify-between items-center">
        <div>
            <h1 class="page-title">Category Management</h1>
            <p class="page-subtitle">Manage your categories with modern interface</p>
        </div>
        <a href="/category/addCategoryPage" class="btn btn-primary" style="padding: 16px 24px; font-weight: 700; font-size: 16px;">
            <i class="fas fa-folder-plus"></i>
            Add New Category
        </a>
    </div>
</div>

<!-- Stats Overview -->
<div class="grid grid-4 mb-3">
    <div class="stat-card fade-in" style="animation-delay: 0.1s; border-left-color: var(--primary);">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <div>
                <div class="stat-number"><%= allCategory ? allCategory.length : 0 %></div>
                <div class="stat-label">Total Categories</div>
            </div>
            <div style="width: 50px; height: 50px; background: rgba(99, 102, 241, 0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                <i class="fas fa-folder" style="color: var(--primary); font-size: 20px;"></i>
            </div>
        </div>
    </div>
</div>

<!-- Main Category List -->
<div class="card fade-in" style="animation-delay: 0.5s;">
    <div class="card-header">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <h3 class="card-title">
                <i class="fas fa-list"></i>
                Category Directory (<%= allCategory ? allCategory.length : 0 %>)
            </h3>
            <div style="display: flex; gap: 12px; align-items: center;">
                <div style="font-size: 12px; color: var(--gray); font-weight: 500;">
                    <i class="fas fa-info-circle"></i>
                    Last updated: <%= new Date().toLocaleDateString() %>
                </div>
            </div>
        </div>
    </div>
    <div class="card-body">
        <% if (allCategory && allCategory.length > 0) { %>
            <div class="table-container">
                <table class="table">
                    <thead>
                        <tr>
                            <th style="width: 80px;">Rank</th>
                            <th>Category Image</th>
                            <th>Category Name</th>
                            <th style="width: 150px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% allCategory.forEach((category, index) => { %>
                        <tr style="animation: fadeInUp 0.6s ease-out; animation-delay: <%= (index + 1) * 0.05 %>s; animation-fill-mode: both;">
                            <td>
                                <div style="width: 45px; height: 45px; background: linear-gradient(135deg, var(--primary), var(--primary-dark)); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 14px; box-shadow: var(--shadow);">
                                    #<%= index + 1 %>
                                </div>
                            </td>
                            <td>
                                <img src="/<%= category.category_image %>" alt="<%= category.category_name %>" class="avatar" style="width: 60px; height: 60px; object-fit: cover;">
                            </td>
                            <td>
                                <div style="font-weight: 700; color: var(--dark); font-size: 16px;">
                                    <%= category.category_name %>
                                </div>
                            </td>
                            <td>
                                <div class="flex gap-2">
                                    <a href="/category/editCategoryPage/<%= category._id %>" class="btn btn-warning" style="padding: 10px 14px; font-size: 12px; font-weight: 600;" title="Edit Category">
                                        <i class="fas fa-edit"></i>
                                        Edit
                                    </a>
                                    <a href="javascript:void(0)" class="btn btn-danger" style="padding: 10px 14px; font-size: 12px; font-weight: 600;" onclick="deleteCategory('<%= category._id %>')" title="Delete Category">
                                        <i class="fas fa-trash"></i>
                                        Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="text-center p-2">
                <div style="width: 140px; height: 140px; background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(99, 102, 241, 0.05)); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 32px; border: 3px dashed var(--primary);">
                    <i class="fas fa-folder" style="font-size: 56px; color: var(--primary);"></i>
                </div>
                <h3 style="color: var(--dark); margin-bottom: 16px; font-weight: 800; font-size: 28px;">No Categories Found</h3>
                <p style="color: var(--gray); margin-bottom: 32px; font-size: 16px; font-weight: 500; max-width: 400px; margin-left: auto; margin-right: auto;">Your category list is empty. Start organizing your content by adding the first category.</p>
                <a href="/category/addCategoryPage" class="btn btn-primary" style="padding: 20px 40px; font-weight: 700; font-size: 18px; border-radius: var(--radius-lg);">
                    <i class="fas fa-folder-plus"></i>
                    Add First Category
                </a>
            </div>
        <% } %>
    </div>
</div>

<%- include('../footer') %>

<script>
function deleteCategory(categoryId) {
    if (confirm('⚠️ Are you sure you want to delete this category?\\n\\nThis action cannot be undone!')) {
        window.location.href = '/category/deleteCategory?categoryId=' + categoryId;
    }
}
</script>
